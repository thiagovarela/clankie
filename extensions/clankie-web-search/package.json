{
  "name": "@clankie/web-search",
  "version": "0.3.0",
  "description": "Headless web search and page extraction for clankie using CloakBrowser + Playwright",
  "type": "module",
  "license": "MIT",
  "files": [
    "src/",
    "package.json",
    "README.md"
  ],
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "typecheck": "npx tsgo --noEmit"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cloakbrowser": "^0.3.10",
    "html-to-markdown-node": "^2.18.0",
    "jsdom": "^27.0.1",
    "playwright-core": "^1.55.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7"
  }
}
