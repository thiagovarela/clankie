{
	"name": "@clankie/memory",
	"version": "0.6.0",
	"description": "Persistent memory with TursoDB native vector search for clankie",
	"type": "module",
	"license": "MIT",
	"files": [
		"src/",
		"skills/",
		"package.json",
		"README.md"
	],
	"keywords": [
		"pi-package"
	],
	"scripts": {
		"typecheck": "npx tsgo --noEmit",
		"test:model": "npx tsx tests/model-load.ts",
		"test:model:strict": "MEMORY_TEST_STRICT=1 npx tsx tests/model-load.ts"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		],
		"skills": [
			"./skills"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*"
	},
	"dependencies": {
		"@huggingface/transformers": "^3.4.0",
		"@tursodatabase/database": "^0.5.0",
		"glob": "^11.0.0"
	},
	"devDependencies": {
		"tsx": "^4.20.5"
	}
}
